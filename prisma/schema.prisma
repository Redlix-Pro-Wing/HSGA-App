// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Admin {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  password    String
  name        String
  designation String
  phone       String
  otp         String?
}

model Employee {
  id             String   @id // holds custom generated IDs like HSGA/TG/SM00053 or HSGA/TG/GC/00053
  name           String
  email          String   @unique
  gender         String
  password       String
  otp            String?
  createdAt      DateTime @default(now())
  // Extended profile fields
  designation    String?
  district       String?
  phone          String?
  assignedSchool String?
  address        String?
  imageUrl       String?
}

model School {
  id                               Int      @id @default(autoincrement())
  name                             String
  address                          String
  district                         String
  principalName                    String
  principalPhone                   String
  scoutInchargeName                String
  scoutInchargePhone               String
  petName                          String
  petPhone                         String
  scoutingStarted                  String   // Month & Year input
  uniformsDistributed              Int
  scarfsDistributed                Int
  scoutMasterName                  String
  praveshikaRegisteredStudents     Int
  praveshikaExamDate               String
  komalPadhRegisteredStudents      Int
  komalPadhExamDate                String
  dhruvPadhRegisteredStudents      Int
  dhruvPadhExamDate                String
  guruPadhRegisteredStudents       Int
  guruPadhExamDate                 String
  rajyaPuraskar                    String
  createdAt                        DateTime @default(now())
}

model TimeTable {
  id           Int      @id @default(autoincrement())
  employeeName String
  monday_1     String   @default("Free")
  monday_2     String   @default("Free")
  monday_3     String   @default("Free")
  monday_4     String   @default("Free")
  tuesday_1    String   @default("Free")
  tuesday_2    String   @default("Free")
  tuesday_3    String   @default("Free")
  tuesday_4    String   @default("Free")
  wednesday_1  String   @default("Free")
  wednesday_2  String   @default("Free")
  wednesday_3  String   @default("Free")
  wednesday_4  String   @default("Free")
  thursday_1   String   @default("Free")
  thursday_2   String   @default("Free")
  thursday_3   String   @default("Free")
  thursday_4   String   @default("Free")
  friday_1     String   @default("Free")
  friday_2     String   @default("Free")
  friday_3     String   @default("Free")
  friday_4     String   @default("Free")
  saturday_1   String   @default("Free")
  saturday_2   String   @default("Free")
  saturday_3   String   @default("Free")
  saturday_4   String   @default("Free")
  workingHours Int      @default(0)
  createdAt    DateTime @default(now())
}

model SchoolVisit {
  id            Int      @id @default(autoincrement())
  employeeEmail String
  schoolName    String
  district      String?
  demonstration Boolean
  visited       Boolean
  principalName String?
  phone         String?
  address       String?
  createdAt     DateTime @default(now())
}

model DailyRegister {
  id              Int      @id @default(autoincrement())
  employeeEmail   String
  schoolName      String
  date            String
  topicCovered    String
  attendanceCount Int
  createdAt       DateTime @default(now())
}

model StudentEnrolment {
  id            Int      @id @default(autoincrement())
  employeeEmail String
  studentName   String
  age           Int
  schoolName    String
  validId       String
  createdAt     DateTime @default(now())
}

model UniformDistribution {
  id               Int      @id @default(autoincrement())
  employeeEmail    String
  schoolName       String
  distributionType String   // "bulk" or "individual"
  maleCount        Int?
  femaleCount      Int?
  studentName      String?
  class            String?
  gender           String?
  amount           Float
  createdAt        DateTime @default(now())
}

model Mou {
  id              Int      @id @default(autoincrement())
  employeeEmail   String
  school          String
  principal       String
  dateInitiated   String
  studentStrength Int
  status          String
  signedDate      String?
  nextFollowUp    String?
  staff           String
  createdAt       DateTime @default(now())
}

model OfficeCall {
  id            Int      @id @default(autoincrement())
  employeeEmail String
  date          String
  school        String
  principal     String
  phone         String
  purpose       String
  response      String
  meetingFixed  Boolean
  followUpReq   Boolean
  createdAt     DateTime @default(now())
}

model HomeCall {
  id              Int      @id @default(autoincrement())
  employeeEmail   String
  date            String
  school          String
  personContacted String
  purpose         String
  response        String
  followUp        Boolean
  staff           String
  createdAt       DateTime @default(now())
}

model PublicRelation {
  id             Int      @id @default(autoincrement())
  employeeEmail  String
  date           String
  personBodyMet  String
  category       String
  purpose        String
  outcome        String
  staff          String
  createdAt      DateTime @default(now())
}

model StudentVideo {
  id            Int      @id @default(autoincrement())
  employeeEmail String
  date          String
  school        String
  title         String
  platform      String
  views         Int
  likes         Int
  link          String
  createdAt     DateTime @default(now())
}

model FinancialRecord {
  id            Int      @id @default(autoincrement())
  employeeEmail String
  date          String
  head          String
  type          String
  amount        Float
  billUrl       String?
  remarks       String?
  createdAt     DateTime @default(now())
}

model ProblemRecord {
  id              Int      @id @default(autoincrement())
  employeeEmail   String
  date            String
  category        String
  description     String
  supportRequired String
  status          String
  raisedBy        String
  createdAt       DateTime @default(now())
}

model DocumentRecord {
  id            Int      @id @default(autoincrement())
  employeeEmail String
  date          String
  title         String
  category      String
  link          String?
  uploadedBy    String
  createdAt     DateTime @default(now())
}

model SocialMediaReport {
  id            Int      @id @default(autoincrement())
  employeeEmail String
  date          String
  platform      String
  postTitle     String
  reach         Int
  likes         Int
  link          String
  createdAt     DateTime @default(now())
}


